# ──────────────────────────────────────────────
# Agent B - Whale Monitor 환경변수 템플릿
# 이 파일을 복사해서 .env로 이름 바꾸고, 실제 값을 채워넣으세요.
# cp .env.example .env
# ──────────────────────────────────────────────

# Supabase (데이터베이스)
# 확인 방법: Supabase 대시보드 → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Bitquery API (고래 거래 감지 - 무료 플랜 사용)
# Whale Alert 대신 Bitquery 사용 (완전 무료)
# 가입: https://bitquery.io → Sign up → Developer Plan
# 지원: BTC, ETH, SOL 등 40개 체인, 실시간 스트림 2개
BITQUERY_API_KEY=BQY...your-bitquery-api-key

# Expo Push Notifications (앱 알림)
# 확인 방법: https://expo.dev → Account Settings → Access Tokens
EXPO_ACCESS_TOKEN=your-expo-access-token-here
