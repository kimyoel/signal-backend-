# ──────────────────────────────────────────────
# .env.example — 환경변수 템플릿
# ──────────────────────────────────────────────
# 이 파일을 복사해서 .env로 이름 바꾸고, 실제 값을 채워넣으세요.
#
# 1. 이 파일 복사:  cp .env.example .env
# 2. .env 열어서 각 값 채우기
# 3. .env 파일은 절대 GitHub에 올리면 안 됨! (.gitignore에 포함됨)
# ──────────────────────────────────────────────

# Supabase (데이터베이스)
# 확인 방법: Supabase 대시보드 → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Whale Alert API (고래 거래 감지)
# 가입: https://whale-alert.io → My Account → API Key
WHALE_ALERT_API_KEY=your-whale-alert-api-key-here

# Expo Push Notifications (앱 알림)
# 확인 방법: https://expo.dev → Account Settings → Access Tokens
EXPO_ACCESS_TOKEN=your-expo-access-token-here
