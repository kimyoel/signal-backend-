# ============================================
# 에이전트 E — 환경변수 설정 파일
# ============================================
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채워 넣으세요
# cp .env.example .env
# ============================================

# --- Supabase ---
# 확인: Supabase 대시보드 → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- AI API Keys ---
# OpenAI (GPT) — https://platform.openai.com 에서 발급
OPENAI_API_KEY=sk-proj-...

# Google AI (Gemini) — https://aistudio.google.com 에서 발급
GOOGLE_AI_API_KEY=AIza...

# xAI (Grok) — https://x.ai/api 에서 발급
XAI_API_KEY=xai-...

# Anthropic (Claude) — https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# --- 설정 ---
CACHE_TTL_HOURS=24
MAX_TOKENS_PER_MODEL=500
RATE_LIMIT_PER_USER_PER_DAY=100
PORT=8000
